<!DOCTYPE html>
<html lang="{{.Locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{if .IsInbox}}{{index .T "notes.inbox"}} — {{else if .IsTagView}}#{{.ActiveTag}} — {{else if .Notebook}}{{.Notebook.Name}} — {{end}}{{index .T "notes.page_title"}}</title>
  {{template "head-assets" .}}
</head>
<body class="workspace-page"
  data-msg-editing="{{index .T "note.editing_mode"}}"
  data-msg-list-updated="{{index .T "notes.list_updated"}}">

  {{/* ── Dialogs — rendered in the DOM but hidden until opened ── */}}
  {{template "dialog-new-note" .}}
  {{template "dialog-new-notebook" .}}
  {{template "dialog-command-palette" .}}

  <div class="workspace">

    <div class="workspace-main-wrapper">
      {{template "site-header" .}}
      {{template "status-region" .}}

    <!--
      Main content is rendered FIRST in the DOM so that the page's <h1>
      precedes the sidebar's <h2> in document outline order, satisfying
      WCAG 1.3.1 and producing a clean heading hierarchy for screen
      readers.  CSS grid then places it visually in the right column.
    -->
    <main id="main-content" class="workspace-main">
      <div class="workspace-main-inner">

        <h1 class="page-heading">
          {{if .IsInbox}}{{index .T "notes.inbox"}}{{else if .IsTagView}}{{index .T "tags.page_title"}} #{{.ActiveTag}}{{else if .Notebook}}{{.Notebook.Name}}{{else}}{{index .T "dashboard.heading"}}{{end}}
        </h1>

        <!-- ── Search ── -->
        <section class="section-group" aria-labelledby="search-heading">
          {{/*
            The heading is visually hidden; the visible <label> on the
            input already describes the control.  The sr-only h2 keeps
            the document outline intact for assistive technologies that
            navigate by heading.
          */}}
          <h2 id="search-heading" class="sr-only">{{index .T "notes.search_label"}}</h2>
          <div role="search">
            <div class="form-group">
              <label for="global-search">{{index .T "notes.search_label"}}</label>
              <input id="global-search"
                     type="search"
                     name="q"
                     autocomplete="off"
                     spellcheck="false"
                     hx-get="/search"
                     hx-trigger="keyup changed delay:400ms, search"
                     hx-target="#search-results"
                     hx-indicator="#search-indicator"
                     aria-controls="search-results"
                     aria-describedby="search-hint">
              <span id="search-hint" class="sr-only">{{index .T "notes.search_hint"}}</span>
            </div>
            <p class="search-status">
              <span id="search-indicator" class="htmx-indicator" aria-hidden="true">{{index .T "notes.searching"}}</span>
            </p>
          </div>
          <div id="search-results"
               role="region"
               aria-label="{{index .T "notes.search_results_label"}}"
               aria-live="polite"
               aria-atomic="true"></div>
        </section>

        <hr class="divider">

        {{/*
          ── Notebook Index Note banner ──────────────────────────────────
          When the user is viewing a specific Notebook and the notebook has
          an Index Note (tagged #index), its rendered HTML is shown here as
          a wiki-style overview.  Headings inside have id attributes injected
          by addHeadingIDs, so sidebar ToC anchor links (#heading-id) resolve
          correctly within this scrollable container.
        */}}
        {{if .IndexNote}}
        <section class="notebook-index" aria-labelledby="notebook-index-heading">
          <h2 id="notebook-index-heading" class="sr-only">{{index .T "notebook.index_heading"}}</h2>
          <div class="note-body">
            {{.IndexNote.RenderedHTML}}
          </div>
          <a href="/notes/{{.IndexNote.ID}}"
             class="btn btn-ghost btn-sm notebook-index__edit-link">
            {{index .T "notebook.edit_index_note"}}
          </a>
        </section>
        <hr class="divider">
        {{end}}

        {{if and (not .IsInbox) (not .IsTagView) (not .Notebook)}}
        <!-- ── Root Dashboard ── -->
        <div class="dashboard">

          <section class="dashboard-card section-group" aria-labelledby="dash-inbox-heading">
            <h2 id="dash-inbox-heading">{{index .T "notes.inbox"}}</h2>
            <p class="dashboard-card__meta">
              {{.InboxCount}} {{index .T "notes.inbox_count_aria"}}
            </p>
            <a href="/inbox" class="btn btn-ghost">{{index .T "dashboard.view_inbox"}}</a>
          </section>

          <hr class="divider">

          <section class="dashboard-card section-group" aria-labelledby="dash-notebooks-heading">
            <h2 id="dash-notebooks-heading">{{index .T "dashboard.your_notebooks"}}</h2>
            {{if .Notebooks}}
            <ul class="dashboard-notebooks" role="list">
              {{range .Notebooks}}
              <li>
                <a href="/notebooks/{{.ID}}">{{.Name}}</a>
              </li>
              {{end}}
            </ul>
            {{else}}
            <p class="dashboard-empty">{{index .T "dashboard.notebooks_empty"}}</p>
            {{end}}
          </section>

        </div>
        {{else}}
        <!-- ── Contextual Notes list (Inbox / Tag / Notebook) ── -->
        <section aria-labelledby="notes-list-heading">
          <h2 id="notes-list-heading">
            {{if .IsInbox}}{{index .T "notes.inbox"}}{{else if .IsTagView}}#{{.ActiveTag}}{{else}}{{index .T "notes.all_notes"}}{{end}}
          </h2>
          {{if .Notes}}
          <ul class="notes-list" id="notes-list" role="list">
            {{range .Notes}}
            {{template "note_item_fragment" (dict "ID" .ID "Title" .Title "UpdatedAt" .UpdatedAt "T" $.T)}}
            {{end}}
          </ul>
          {{else}}
          <p>{{if .IsInbox}}{{index .T "notes.inbox_empty"}}{{else if .IsTagView}}{{index .T "tags.empty_state"}}{{else}}{{index .T "notes.empty_state"}}{{end}}</p>
          {{end}}
        </section>
        {{end}}

      </div><!-- /.workspace-main-inner -->
    </main><!-- /#main-content -->

    </div><!-- /.workspace-main-wrapper -->

    {{template "workspace-sidebar" .}}

  </div><!-- /.workspace -->

  <script>
    /* After an HTMX swap: move focus to a meaningful element and
       announce the state change through the ARIA live region. */
    document.body.addEventListener('htmx:afterSwap', function (ev) {
      var statusEl = document.getElementById('system-status');
      setTimeout(function () {
        var textarea = ev.detail.target.querySelector('textarea');
        if (textarea) {
          textarea.focus();
          if (statusEl) statusEl.textContent = document.body.dataset.msgEditing;
          return;
        }
        var heading = ev.detail.target.querySelector('h3, h2');
        if (heading) {
          heading.setAttribute('tabindex', '-1');
          heading.focus();
        }
        if (statusEl) statusEl.textContent = document.body.dataset.msgListUpdated;
      }, 80);
    });

    /*
      ToC smooth scroll — required because .workspace-main is its own
      overflow-y: auto scroll container.  Native anchor navigation scrolls
      the viewport; we intercept sidebar ToC clicks and call
      scrollIntoView on the target heading inside the container instead.
    */
    document.addEventListener('click', function (ev) {
      var link = ev.target.closest('.sidebar-toc a');
      if (!link) return;
      var hash = link.getAttribute('href');
      if (!hash || hash.charAt(0) !== '#') return;
      var target = document.getElementById(hash.slice(1));
      if (!target) return;
      ev.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      /* Keep the URL hash in sync for bookmarkability / back-navigation. */
      if (window.history && window.history.pushState) {
        window.history.pushState(null, '', hash);
      }
      /* Move focus to the heading so keyboard users land on the right spot. */
      if (!target.hasAttribute('tabindex')) {
        target.setAttribute('tabindex', '-1');
      }
      target.focus({ preventScroll: true });
    });
  </script>
</body>
</html>