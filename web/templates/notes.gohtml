<!DOCTYPE html>
<html lang="{{.Locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{if .Notebook}}{{.Notebook.Name}} — {{end}}{{index .T "notes.page_title"}}</title>
  {{template "head-assets" .}}
</head>
<body class="workspace-page"
  data-msg-editing="{{index .T "note.editing_mode"}}"
  data-msg-list-updated="{{index .T "notes.list_updated"}}">

  {{template "site-header" .}}
  {{template "status-region" .}}

  {{/* ── Dialogs — rendered in the DOM but hidden until opened ── */}}
  {{template "dialog-new-note" .}}
  {{template "dialog-new-notebook" .}}
  {{template "dialog-command-palette" .}}

  <div class="workspace">

    <!--
      Main content is rendered FIRST in the DOM so that the page's <h1>
      precedes the sidebar's <h2> in document outline order, satisfying
      WCAG 1.3.1 and producing a clean heading hierarchy for screen
      readers.  CSS grid then places it visually in the right column.
    -->
    <main id="main-content" class="workspace-main">
      <div class="workspace-main-inner">

        <h1 class="page-heading">
          {{if .Notebook}}{{.Notebook.Name}}{{else}}{{index .T "notes.heading"}}{{end}}
        </h1>

        <!-- ── Search ── -->
        <section class="section-group" aria-labelledby="search-heading">
          {{/*
            The heading is visually hidden; the visible <label> on the
            input already describes the control.  The sr-only h2 keeps
            the document outline intact for assistive technologies that
            navigate by heading.
          */}}
          <h2 id="search-heading" class="sr-only">{{index .T "notes.search_label"}}</h2>
          <div role="search">
            <div class="form-group">
              <label for="global-search">{{index .T "notes.search_label"}}</label>
              <input id="global-search"
                     type="search"
                     name="q"
                     autocomplete="off"
                     spellcheck="false"
                     hx-get="/search"
                     hx-trigger="keyup changed delay:400ms, search"
                     hx-target="#search-results"
                     hx-indicator="#search-indicator"
                     aria-controls="search-results"
                     aria-describedby="search-hint">
              <span id="search-hint" class="sr-only">{{index .T "notes.search_hint"}}</span>
            </div>
            <p class="search-status">
              <span id="search-indicator" class="htmx-indicator" aria-hidden="true">{{index .T "notes.searching"}}</span>
            </p>
          </div>
          <div id="search-results"
               role="region"
               aria-label="{{index .T "notes.search_results_label"}}"
               aria-live="polite"
               aria-atomic="true"></div>
        </section>

        <hr class="divider">

        <!-- ── Notes list ── -->
        <section aria-labelledby="notes-list-heading">
          <h2 id="notes-list-heading">{{index .T "notes.all_notes"}}</h2>
          {{if .Notes}}
          <ul class="notes-list" id="notes-list" role="list">
            {{range .Notes}}
            {{template "note_item_fragment" .}}
            {{end}}
          </ul>
          {{else}}
          <p>{{index .T "notes.empty_state"}}</p>
          {{end}}
        </section>

      </div><!-- /.workspace-main-inner -->
    </main><!-- /#main-content -->

    <!--
      Sidebar: rendered SECOND in the DOM (after main) so heading order
      is correct, but placed visually in column 1 via `grid-column: 1`.

      The "New Note" and "New Notebook" forms have been replaced by
      placeholder <button> elements.  They are wired to modals in a
      future iteration; for now they carry proper semantics, accessible
      labels, and high-contrast focus states (.sidebar-btn).
    -->
    <nav class="workspace-sidebar" aria-label="{{index .T "nav.main_label"}}">

      <!-- ── Action buttons ── -->
      <div class="sidebar-actions">
        <button id="btn-new-note"
                type="button" class="btn btn-primary sidebar-btn"
                data-open-dialog="dlg-new-note"
                aria-label="{{index .T "notes.new_note"}}">
          <svg aria-hidden="true" focusable="false"
               viewBox="0 0 20 20" fill="none" width="1em" height="1em">
            <path d="M10 4v12M4 10h12"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          {{index .T "notes.new_note"}}
        </button>
        <button id="btn-new-notebook"
                type="button" class="btn btn-ghost sidebar-btn"
                data-open-dialog="dlg-new-notebook"
                aria-label="{{index .T "notes.new_notebook"}}">
          <svg aria-hidden="true" focusable="false"
               viewBox="0 0 20 20" fill="none" width="1em" height="1em">
            <path d="M10 4v12M4 10h12"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          {{index .T "notes.new_notebook"}}
        </button>
      </div>

      <!-- ── Notebooks list ── -->
      <section class="sidebar-section" aria-labelledby="notebooks-heading">
        <h2 class="sidebar-heading" id="notebooks-heading">{{index .T "notes.notebooks_heading"}}</h2>
        <ul class="notebook-list" role="list">
          <li>
            <a href="/notes"
               {{if not .Notebook}}aria-current="page"{{end}}>
              {{index .T "notes.all_notes"}}
            </a>
          </li>
          {{range .Notebooks}}
          <li>
            <a href="/notebooks/{{.ID}}"
               {{if and $.Notebook (eq $.Notebook.ID .ID)}}aria-current="page"{{end}}>
              {{.Name}}
            </a>
          </li>
          {{end}}
        </ul>
      </section>

    </nav><!-- /.workspace-sidebar -->

  </div><!-- /.workspace -->

  <script>
    /* After an HTMX swap: move focus to a meaningful element and
       announce the state change through the ARIA live region. */
    document.body.addEventListener('htmx:afterSwap', function (ev) {
      var statusEl = document.getElementById('system-status');
      setTimeout(function () {
        var textarea = ev.detail.target.querySelector('textarea');
        if (textarea) {
          textarea.focus();
          if (statusEl) statusEl.textContent = document.body.dataset.msgEditing;
          return;
        }
        var heading = ev.detail.target.querySelector('h3, h2');
        if (heading) {
          heading.setAttribute('tabindex', '-1');
          heading.focus();
        }
        if (statusEl) statusEl.textContent = document.body.dataset.msgListUpdated;
      }, 80);
    });
  </script>
</body>
</html>