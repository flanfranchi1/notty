<!DOCTYPE html>
<html lang="{{.Locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{.Title}} — notty</title>
  {{template "head-assets" .}}
</head>
<body class="workspace-page"
      data-msg-editing="{{index .T "note.editing_mode"}}"
      data-msg-viewing="{{index .T "note.view_mode"}}">
  {{template "dialog-new-note" .}}
  {{template "dialog-new-notebook" .}}
  {{template "dialog-command-palette" .}}

  <div class="workspace">
    <div class="workspace-main-wrapper">
      {{template "site-header" .}}
      {{template "status-region" .}}

      <main id="main-content" class="workspace-main note-workspace">
        <div class="note-topbar">
          <nav class="breadcrumb" aria-label="{{index .T "nav.breadcrumb_label"}}">
            <a href="/notes">← {{index .T "notes.all_notes"}}</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page" id="note-page-title">{{.Title}}</span>
          </nav>
        </div>

        <div id="note-display-area">
          {{template "note_view_fragment" .}}
        </div>
      </main>
    </div>

    {{template "workspace-sidebar" .}}
  </div>

  <script>
    document.body.addEventListener('htmx:afterSwap', function (ev) {
      if (ev.detail.target.id !== 'note-display-area') return;
      var statusEl = document.getElementById('system-status');
      setTimeout(function () {
        if (document.getElementById('editor-textarea')) {
          if (statusEl) statusEl.textContent = document.body.dataset.msgEditing;
          return;
        }
        var editBtn = document.getElementById('edit-button');
        if (editBtn) {
          editBtn.focus();
          if (statusEl) statusEl.textContent = document.body.dataset.msgViewing;
        }
      }, 80);
    });
  </script>
</body>
</html>